DATABASE_URL=
REDIS_URL=


JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:5174

APP_ENV=development
# Comma-separated list of allowed origins for the frontend (see ../frontend).
# Leaving this blank disables CORS entirely, which breaks the Vite dev server.
# IMPORTANT: Must match the port where your frontend Vite server is running (default 5174)
CORS_ORIGINS=http://localhost:5174


# Cloudflare R2 (photo storage) — create an R2 API token in the Cloudflare dashboard
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=